def unlock(sub_args):
    """Unlocks a previous runs output directory. If snakemake fails ungracefully,
    it maybe required to unlock the working directory before proceeding again.
    This is rare but it does occasionally happen. Maybe worth add a --force
    option to delete the '.snakemake/' directory in the future.
    @param sub_args <parser.parse_args() object>:
        Parsed arguments for unlock sub-command
    """
    # Check for required dependencies
    require(['snakemake'],['snakemake'])
    print("Unlocking the pipeline's output directory...")
    outdir = sub_args.output
    try:
        subprocess.check_output([
            'snakemake', '--unlock',
            '--cores', '1',
            '--configfile=config.json'
        ], cwd = outdir,
        stderr=subprocess.STDOUT)
    except subprocess.CalledProcessError as e:
        # Unlocking process returned a non-zero exit code
        sys.exit("{0}\n{1}".format(e, e.output))

    print("Successfully unlocked the pipeline's working directory!")


def run(sub_args):
    """Initialize, setup, and run the pipeline.
    Calls init() to create the output directory and copy over pipeline resources,
    setup() to create the pipeline config file, dryrun() to ensure there are no
    issues before running the pipeline, and finally runner() to execute the
    Snakemake workflow.
    @param sub_args <parser.parse_args() object>:
        Parsed arguments for run sub-command
    """
    # Check for required dependencies, i.e:
    # snakemake and singularity/apptainer
    require(['snakemake', 'singularity'], ['snakemake', 'singularity'])
    check_snakemake_version()  # requires snakemake < 8.0
    # Initialize pipeline output directory, copy
    # over required files for running the pipeline,
    # and build the pipelines main config file
    config = build_config(sub_args, __home__)
    save_config(config, sub_args.output)

    if sub_args.dry_run:
        # dryrun() returns a byte-string representation in python3
        dryrun_output = dryrun(outdir=sub_args.output)
        print("\nDry-running {0} pipeline:\n{1}".format(
            _name, dryrun_output.decode("utf-8"))
        )
        sys.exit(0)

    # Kick off the pipeline or sumbit the main
    # job if running the pipeline in slurm mode
    mjob = launch_pipeline(sub_args, config['bindpaths'], __home__, _name)
    report_outcome(sub_args, mjob, _name)


def install(sub_args):
    """Downloads resource bundle locally in parallel chunks.
    Reference files will be pulled from chunks defined in
    'config/install.json' onto the local filesystem. This
    function is a wrapper to 'src/download.py'. Please see
    that script for more information.
    @param sub_args <parser.parse_args() object>:
        Parsed arguments for install sub-command
    """
    # Read in config/install.json containing
    # resource bundle tarball shards
    install_config = read_install_config(__home__)
    targets = install_config['install']

    if not has_downloads(targets):
        print(
            'Nothing to download! The pipeline is setup and ready to run.',
            '\nThis pipeline already has all of its references bundled here:',
            '\n  • {0}'.format(os.path.join(__home__, 'resources'))
        )
        sys.exit(0)
    # Downloads all tarball shards in parallel
    # if the --dry-run option is not provided
    for target, chunks in targets.items():
        download_target(sub_args, chunks)

    if not sub_args.dry_run:
        # Construct the resource bundle
        # from downloaded shards, concatenates
        # the shards and extracts the tarball
        for target, chunks in targets.items():
            assemble_target(sub_args, chunks)


def cache(sub_args):
    """Caches remote software containers stored on DockerHub.
    Local SIFs will be created from images defined in 'config/containers.json'.
    @param sub_args <parser.parse_args() object>:
        Parsed arguments for cache sub-command
    """
    # Check for required dependencies,
    # i.e singularity/apptainer
    require(['singularity'], ['singularity'])
    sif_cache = sub_args.sif_cache
    repo_path = os.path.dirname(os.path.abspath(__file__))
    images_config = os.path.join(repo_path, 'config', 'containers.json')
    # Initialize the SIF cache directory
    prepare_cache(sif_cache, _name)
    # Get list of images that are missing
    # from the SIF cache, these images will
    # be pulled/cached locally
    uris_to_pull = missing_images(images_config, sif_cache)

    if not uris_to_pull:
        # Nothing to do, we already have a
        # local cache of everything
        print('Singularity image cache is already up to date!')
        return

    if sub_args.dry_run:
        return

    # Pull missing images from container
    # registries and cache them locally
    pull_images(repo_path, sif_cache, uris_to_pull)


class CliHelpFormatter(argparse.HelpFormatter):
    """Custom help formatter to improve the formatting of help messages.
    This formatter increases the max_help_position and width to allow for
    increasingly long option names and help messages without breaking
    formatting.
    """
    def __init__(self, prog):
        super().__init__(
            prog,
            max_help_position=36,
            width=100,
        )


def parsed_arguments(name, description):
    """Parses user-provided command-line arguments. Requires argparse and textwrap
    package. argparse was added to standard lib in python 3.5 and textwrap was added
    in python 3.5. To create custom help formatting for subparsers a docstring is
    used create the help message for required options. argparse does not support named
    subparser groups, which is normally what would be used to accomphish this reformatting.
    As so, the help message for require options must be suppressed. If a new required arg
    is added to a subparser, it must be added to the docstring and the usage statement
    also must be updated.
    @param name <str>:
        Name of the pipeline or command-line tool
    @param description <str>:
        Short description of pipeline or command-line tool
    """
