    c = Colors()
    styled_name = f"{c.bold}{name}{c.end}"
    styled_description = f"{c.bold}{c.italic}{description}{c.end}"

    # Create the top-level parser with a custom
    # help formatter and stylized description.
    parser = argparse.ArgumentParser(
        prog=name,
        description=f"{styled_name}: {styled_description}",
        formatter_class=CliHelpFormatter,
        add_help=False,
    )

    # Stylized section titles for sub-commands
    # and top-level options
    parser._positionals.title = f"{c.url}List of available sub-commands{c.end}"
    parser._optionals.title = f"{c.url}Top-level options{c.end}"

    # Top-level cli options
    # Custom help option
    parser.add_argument(
        "-h",
        "--help",
        action="help",
        help="Show help information and exit.",
    )
    # Pipeline version information
    parser.add_argument(
        "-v",
        "--version",
        action="version",
        version=f"%(prog)s {__version__}",
        help="Show pipeline version and exit.",
    )

    # Setup sub-parsers for each subcommand, along
